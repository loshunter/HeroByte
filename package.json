{
  "name": "herobyte",
  "version": "0.9.0-beta.1",
  "type": "module",
  "description": "A real-time multiplayer virtual tabletop for tabletop RPG gaming",
  "main": "index.js",
  "scripts": {
    "dev:server:raw": "pnpm --filter vtt-server dev",
    "dev:client:raw": "pnpm --filter herobyte-client dev",
    "dev:server": "node scripts/dev-port-preflight.mjs ensure-free --service server && pnpm dev:server:raw",
    "dev:client": "node scripts/dev-port-preflight.mjs ensure-free --service client && pnpm dev:client:raw",
    "dev:doctor": "node scripts/dev-port-preflight.mjs doctor",
    "dev:free": "node scripts/dev-port-preflight.mjs free",
    "dev": "node scripts/dev-port-preflight.mjs ensure-free && concurrently -k -n \"server,client\" -c \"blue,green\" \"pnpm dev:server:raw\" \"pnpm dev:client:raw\"",
    "build:server": "pnpm --filter vtt-server build",
    "build:client": "pnpm --filter herobyte-client build",
    "build": "pnpm build:server && pnpm build:client",
    "test": "pnpm -r --workspace-concurrency=2 run test",
    "test:parallel": "pnpm test:shared & pnpm test:server & pnpm test:client & wait",
    "test:sequential": "pnpm test:shared && pnpm test:server && pnpm test:client",
    "test:ci": "pnpm --filter './...' test",
    "test:coverage": "pnpm test:shared:coverage && pnpm test:server:coverage && pnpm test:client:coverage",
    "test:coverage:parallel": "pnpm test:shared:coverage & pnpm test:server:coverage & pnpm test:client:coverage & wait",
    "test:shared": "pnpm --filter @herobyte/shared test",
    "test:shared:coverage": "pnpm --filter @herobyte/shared test:coverage",
    "test:server": "pnpm --filter vtt-server test",
    "test:server:coverage": "pnpm --filter vtt-server test:coverage",
    "test:client": "pnpm --filter herobyte-client test",
    "test:client:coverage": "pnpm --filter herobyte-client test:coverage",
    "lint": "pnpm lint:shared && pnpm lint:server && pnpm lint:client && pnpm lint:frozen",
    "lint:frozen": "node scripts/check-frozen-tests.mjs",
    "typecheck": "pnpm --filter vtt-server typecheck && pnpm --filter herobyte-client typecheck",
    "lint:client": "pnpm --filter herobyte-client lint",
    "lint:server": "pnpm --filter vtt-server lint",
    "lint:shared": "pnpm --filter @herobyte/shared lint",
    "e2e:doctor": "node scripts/dev-port-preflight.mjs doctor --client-port 5175 --server-port 8788",
    "e2e:free": "node scripts/dev-port-preflight.mjs free --client-port 5175 --server-port 8788",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:ui": "node scripts/run-e2e.mjs --ui",
    "test:e2e:smoke": "node scripts/run-e2e.mjs --grep \"smoke\"",
    "lint:structure": "node scripts/structure-report.mjs --limit 50 --threshold 350",
    "lint:structure:enforce": "node scripts/structure-report.mjs --threshold 350 --fail-on-new",
    "baseline:update": "node scripts/update-baseline.mjs",
    "gen:sfx": "node scripts/generate-sfx.mjs",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,json,md}\" \"packages/**/*.{ts,tsx,js,json,md}\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,json,md}\" \"packages/**/*.{ts,tsx,js,json,md}\" \"*.{js,json,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.56.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "playwright": "^1.56.0",
    "prettier": "^3.6.2"
  }
}
