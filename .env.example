# ============================================================================
# HeroByte server environment (copy to .env and fill in real values)
# ============================================================================

# Room password players must enter to join. If unset, a development fallback
# ("Fun1") is used and a warning is logged. ALWAYS set this in production.
HEROBYTE_ROOM_SECRET=

# Password used to elevate a player to Dungeon Master. Development fallback:
# "FunDM". ALWAYS set this in production.
HEROBYTE_DM_PASSWORD=

# Comma-separated list of allowed HTTP/WebSocket origins.
# Example: https://yourdomain.com,https://staging.yourdomain.com
HEROBYTE_ALLOWED_ORIGINS=

# Explicitly opt in to demo conveniences. When "true" AND no room secret is
# configured, the landing page displays the fallback room password in
# plaintext. Leave unset for any internet-reachable deployment.
HEROBYTE_DEMO_MODE=

# Default room identifier (multi-room support placeholder). Default: "default"
HEROBYTE_DEFAULT_ROOM_ID=

# HTTP/WebSocket port. Default: 8787
PORT=

# Room state backend: "redis" to persist rooms in Redis, anything else for
# in-memory + local JSON file.
ROOM_STORE=
REDIS_URL=

# Custom state file path (used by parallel E2E test runs)
ROOM_STATE_FILE=

# ----------------------------------------------------------------------------
# CI / testing (set as repository secrets, not in .env)
# ----------------------------------------------------------------------------
# CODECOV_TOKEN     - Codecov upload token used by .github/workflows/ci.yml
# E2E_ROOM_PASSWORD - Room password used by Playwright E2E helpers
# E2E_DM_PASSWORD   - DM password used by Playwright E2E helpers
